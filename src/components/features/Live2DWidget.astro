---
import MessageBox from "@/components/common/PioMessageBox.astro";
import type { Live2DModelConfig } from "@/types/config";
import { url } from "@/utils/url-utils";

interface Props {
	config: Live2DModelConfig;
}

const { config } = Astro.props;

// 获取位置和尺寸配置
const position = config.position || {
	corner: "bottom-right" as const,
	offsetX: 20,
	offsetY: 20,
};
const size = config.size || { width: 280, height: 250 };
---

<div
  id="live2d-widget"
  class="live2d-widget"
  style={`
    width: ${size.width}px;
    height: ${size.height}px;
    ${position.corner?.includes("right") ? "right" : "left"}: ${position.offsetX}px;
    ${position.corner?.includes("top") ? "top" : "bottom"}: ${position.offsetY}px;
  `}
>
  <canvas id="live2d-canvas" style={`width: ${size.width}px; height: ${size.height}px;`}></canvas>
</div>

<!-- 引入消息框组件 -->
<MessageBox />

<!-- 加载 Live2D 和 PIXI 核心框架 (顺序很重要) -->
<script is:inline src="https://cubism.live2d.com/sdk-web/cubismcore/live2dcubismcore.min.js"></script>
<script is:inline src="https://cdn.jsdelivr.net/npm/pixi.js@7.x/dist/pixi.min.js"></script>
<!-- 使用专门针对 Cubism 4 的版本，避免 Cubism 2 找不到的报错 -->
<script is:inline src="https://cdn.jsdelivr.net/npm/pixi-live2d-display/dist/cubism4.min.js"></script>

<script is:inline define:vars={{ config, modelPathUrl: url(config.model.path) }}>
  let live2dModel = null;
  let pixiApp = null;
  
  function initLive2D() {
    if (!config.model || !config.model.path) {
      console.error("[Live2D] No model path configured");
      return;
    }

    const canvas = document.getElementById("live2d-canvas");
    if (!canvas) return;

    // 暴露为全局以便拓展
    const PIXI = window.PIXI;
    // 确保 Live2DModel API 已完全挂载
    if (!PIXI || !PIXI.live2d || !PIXI.live2d.Live2DModel) {
        console.warn("[Live2D] PIXI or pixi-live2d-display not loaded yet, retrying...");
        setTimeout(initLive2D, 500);
        return;
    }

    // 初始化 PIXI App (透明背景)
    pixiApp = new PIXI.Application({
      view: canvas,
      autoStart: true,
      backgroundAlpha: 0,
      width: config.size.width,
      height: config.size.height,
      resolution: window.devicePixelRatio || 1,
    });

    // 加载 Live2D 模型
    PIXI.live2d.Live2DModel.from(modelPathUrl).then((model) => {
      pixiApp.stage.addChild(model);
      live2dModel = model;

      // 很多高清模型本身画布极大且周围有大量留白，我们需要强行适配
      // 为了允许用户去“裁切”原模型里过于宽泛的环境（桌椅），我们重新采用基于高度主导的等比缩放算法
      // 这样多出的宽度部分会随着外层设置的极小 width 自然被截断隐藏，同时人物不会随之变小
      const scale = config.size.height / model.internalModel.originalHeight;
      
      // 允许从配置文件中读取额外的 scale 系数
      const extraScale = config.model?.scale || 1.0;
      model.scale.set(scale * extraScale);
      
      const offsetX = config.model?.offsetX || 0;
      const offsetY = config.model?.offsetY || 0;
      
      // 水平和垂直居中计算，加上额外的偏移量来移动画面视角
      model.x = (config.size.width - model.internalModel.originalWidth * model.scale.x) / 2 + offsetX;
      model.y = (config.size.height - model.internalModel.originalHeight * model.scale.y) / 2 + offsetY;

      setupInteractions();
      console.log("[Live2D] Model loaded successfully! Original size:", model.internalModel.originalWidth, "x", model.internalModel.originalHeight);
    }).catch(err => {
        console.error("[Live2D] Failed to load Live2D model:", err);
    });
  }

  function playRandomMotion(model) {
      if (!model.internalModel || !model.internalModel.motionManager) return;
      const motionManager = model.internalModel.motionManager;
      
      // 有些模型的 motions 放在 definitions 里，有的是 motionGroups
      const definitions = motionManager.definitions || motionManager.motionGroups;
      if (!definitions) return;
      
      const groups = Object.keys(definitions);
      if (groups.length === 0) return;
      
      // 排除 idle 等默认组，或者直接随机
      const interactiveGroups = groups.filter(g => !g.toLowerCase().includes('idle'));
      const targetGroups = interactiveGroups.length > 0 ? interactiveGroups : groups;
      
      const randomGroup = targetGroups[Math.floor(Math.random() * targetGroups.length)];
      model.motion(randomGroup);
  }

  function showMessage() {
    const messages = config.interactive?.clickMessages || [
      "你好！",
      "有什么需要帮助的吗？",
    ];
    const randomMessage = messages[Math.floor(Math.random() * messages.length)];

    if (window.showModelMessage) {
      window.showModelMessage(randomMessage, {
        containerId: "live2d-widget",
        displayTime: config.interactive?.messageDisplayTime || 3000
      });
    }
  }

  function setupInteractions() {
    const container = document.getElementById("live2d-widget");
    const canvas = document.getElementById("live2d-canvas");
    if (!container || !canvas) return;

    let isDragging = false;
    let dragStart = { x: 0, y: 0 };
    let containerStart = { x: 0, y: 0 };
    let hasDragged = false;

    // 鼠标点击事件，播放随机动画并弹出文字
    canvas.addEventListener('click', (e) => {
        if (hasDragged) {
            hasDragged = false;
            return;
        }
        if (live2dModel) {
            playRandomMotion(live2dModel);
            showMessage();
            if (typeof window.toggleLumiChat === 'function') {
                window.toggleLumiChat();
            }
        }
    });

    // 鼠标拖动事件
    container.addEventListener("mousedown", (e) => {
      if (e.button !== 0) return;
      isDragging = true;
      hasDragged = false;
      dragStart = { x: e.clientX, y: e.clientY };
      const rect = container.getBoundingClientRect();
      containerStart = { x: rect.left, y: rect.top };
      container.style.cursor = "grabbing";
    });

    document.addEventListener("mousemove", (e) => {
      if (!isDragging) return;
      
      const deltaX = e.clientX - dragStart.x;
      const deltaY = e.clientY - dragStart.y;
      
      if (Math.abs(deltaX) > 5 || Math.abs(deltaY) > 5) {
          hasDragged = true;
      }
      
      const maxX = window.innerWidth - container.offsetWidth;
      const maxY = window.innerHeight - container.offsetHeight;

      const clampedX = Math.max(0, Math.min(containerStart.x + deltaX, maxX));
      const clampedY = Math.max(0, Math.min(containerStart.y + deltaY, maxY));

      container.style.left = clampedX + "px";
      container.style.right = "auto";
      container.style.top = clampedY + "px";
      container.style.bottom = "auto";
    });

    document.addEventListener("mouseup", () => {
      if (isDragging) {
        isDragging = false;
        container.style.cursor = "grab";
      }
    });
    
    // 鼠标跟随 (让模型的眼睛/头一直盯着你的鼠标看)
    document.addEventListener("mousemove", (e) => {
      if(live2dModel && !isDragging) {
          // 转换屏幕坐标为相对画布的坐标 
          const rect = canvas.getBoundingClientRect();
          const x = e.clientX - rect.left;
          const y = e.clientY - rect.top;
          live2dModel.focus(x, y);
      }
    });

    // 窗口边缘防溢出限制
    window.addEventListener("resize", () => {
      const rect = container.getBoundingClientRect();
      const maxX = window.innerWidth - container.offsetWidth;
      const maxY = window.innerHeight - container.offsetHeight;
      if (rect.left > maxX) {
        container.style.left = maxX + "px";
        container.style.right = "auto";
      }
      if (rect.top > maxY) {
        container.style.top = maxY + "px";
        container.style.bottom = "auto";
      }
    });
  }

  function handleResponsive() {
    const widget = document.getElementById("live2d-widget");
    if (!widget) return;
    const responsive = config.responsive;
    if (responsive?.hideOnMobile) {
      const breakpoint = responsive.mobileBreakpoint || 768;
      widget.style.display = window.innerWidth <= breakpoint ? "none" : "block";
    }
  }

  // 开始初始化生命周期
  const startLive2D = () => {
    handleResponsive();
    if (!window.live2DIsStarting) {
      window.live2DIsStarting = true;
      setTimeout(initLive2D, 500);
    }
  };

  if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", startLive2D);
  } else {
      startLive2D();
  }
  
  window.addEventListener("resize", handleResponsive);

  // 兼容 Swup 路由切换 (切换路由时重设显示状态但不销毁)
  if (typeof window.swup !== "undefined" && window.swup.hooks) {
    window.swup.hooks.on("content:replace", () => setTimeout(handleResponsive, 100));
  } else {
    document.addEventListener("swup:enable", () => {
      if (window.swup && window.swup.hooks) {
        window.swup.hooks.on("content:replace", () => setTimeout(handleResponsive, 100));
      }
    });
  }
</script>

<style>
  .live2d-widget {
    position: fixed;
    z-index: 999;
    pointer-events: auto;
    cursor: grab;
  }
  #live2d-canvas {
    pointer-events: auto;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .live2d-widget:hover #live2d-canvas {
    opacity: 1;
  }
  .live2d-widget:active {
    cursor: grabbing;
  }
</style>
